{
  "name": "phototracker",
  "private": true,
  "type": "module",
  "scripts": {
    "web:build": "npm run build --prefix apps/web",
    "web:dev": "npm run dev --prefix apps/web",
    "api:publish": "node scripts/publish-openapi.mjs",
    "dev": "wrangler dev",
    "deploy": "npm run web:build && wrangler deploy",
    "types": "wrangler types",
    "d1:migrations:apply": "wrangler d1 migrations apply phototracker"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.15",
    "jose": "^6.2.3",
    "ulid": "^3.0.2",
    "yaml": "^2.8.3"
  }
}
